# Database (PostgreSQL). Crea la base vacía antes; /install ejecuta migrate deploy y luego el admin.
# Solo DATABASE_URL define el servidor; el provider en prisma/schema.prisma es postgresql.
#
# Next.js: si existe .env.local, sus variables SOBRESCRIBEN .env. Mantén DATABASE_URL
# corregida en el archivo que realmente uses (o elimina DATABASE_URL duplicada en .env.local).
#
# Si ves "invalid port number": suele ser la contraseña (o usuario) con caracteres reservados en URLs
# (@ : # % / ? &). Codifícalos con percent-encoding, p. ej. en Node: encodeURIComponent('tu_contraseña')
# @ -> %40   : -> %3A   # -> %23   % -> %25   / -> %2F
# Formato: postgresql://USUARIO:CONTRASEÑA_CODIFICADA@HOST:PUERTO/NOMBRE_BD?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/prospect_finder?schema=public"

# Google APIs
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your_frontend_google_maps_api_key"
GOOGLE_PLACES_API_KEY="your_backend_google_places_api_key"

# Anthropic Claude API
ANTHROPIC_API_KEY="your_anthropic_api_key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
UPLOAD_DIR="./public/uploads"

# DigitalOcean Spaces (S3-compatible: landings ZIP, API HTML, Claude Code)
# DO_ENDPOINT = URL pública del Space, p. ej. https://tu-bucket.region.digitaloceanspaces.com
DO_ENDPOINT=""
DO_ACCESS_KEY=""
DO_SECRET_KEY=""

# Python web analyzer (POST /api/prospects/:id/analyze). Install: cd web-analyzer && python3 -m venv venv && ./venv/bin/pip install -r requirements.txt && playwright install chromium
WEB_ANALYZER_PATH="./web-analyzer"

# SMTP (outbound email)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="noreply@example.com"
SMTP_PASS="your_smtp_password"
SMTP_FROM="App Name <noreply@example.com>"

# IMAP (inbound email / reply detection)
IMAP_HOST="imap.example.com"
IMAP_PORT="993"
IMAP_USER="inbox@example.com"
IMAP_PASS="your_imap_password"

# Auth (NextAuth.js / Auth.js)
NEXTAUTH_SECRET="generate-a-random-secret-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3000"
# Si corres la app en Docker con -p 3002:3000 (o App Platform detrás de proxy), pon true:
AUTH_TRUST_HOST="false"

# Prisma seed (usuario admin inicial; solo se leen al ejecutar: npx prisma db seed)
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_NAME="Administrator"
SEED_ADMIN_PASSWORD="changeme"

# Instalación web en /install (solo si true). En producción: false o sin definir tras instalar.
ALLOW_INSTALL="true"
